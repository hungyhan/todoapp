pipeline {
    agent any

    environment {
        AWS_ACCOUNT_ID = '527055790396'
        AWS_REGION = 'ap-southeast-1'

        CLIENT_IMAGE_NAME = 'do2602/hungcm-client'
        SERVER_IMAGE_NAME = 'do2602/hungcm-server'

        IMAGE_TAG = "${env.BUILD_NUMBER}"

        ECR_URL = "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com"
    }

    stages {
        stage('Checkout Code') {
            steps {
                echo 'Pulling code from GitHub...'

                git url: 'https://github.com/hungyhan/todoapp.git',
                    branch: 'main',
                    credentialsId: 'do2602-jenkins-github'
            }
        }

        stage('Login to AWS ECR') {
            steps {
                echo 'Login to ECR...'

                sh """
                    aws ecr get-login-password --region ${AWS_REGION} \
                    | docker login \
                        --username AWS \
                        --password-stdin ${ECR_URL}
                """
            }
        }

        stage('Build Client Image') {
            steps {
                echo 'Building client image...'

                sh """
                    docker build \
                        -t ${CLIENT_IMAGE_NAME}:${IMAGE_TAG} \
                        ./client

                    docker tag \
                        ${CLIENT_IMAGE_NAME}:${IMAGE_TAG} \
                        ${ECR_URL}/${CLIENT_IMAGE_NAME}:${IMAGE_TAG}

                    docker tag \
                        ${CLIENT_IMAGE_NAME}:${IMAGE_TAG} \
                        ${ECR_URL}/${CLIENT_IMAGE_NAME}:latest
                """
            }
        }

        stage('Build Server Image') {
            steps {
                echo 'Building server image...'

                sh """
                    docker build \
                        -t ${SERVER_IMAGE_NAME}:${IMAGE_TAG} \
                        ./server

                    docker tag \
                        ${SERVER_IMAGE_NAME}:${IMAGE_TAG} \
                        ${ECR_URL}/${SERVER_IMAGE_NAME}:${IMAGE_TAG}

                    docker tag \
                        ${SERVER_IMAGE_NAME}:${IMAGE_TAG} \
                        ${ECR_URL}/${SERVER_IMAGE_NAME}:latest
                """
            }
        }

        stage('Push Images to ECR') {
            steps {
                echo 'Pushing images to ECR...'

                sh """
                    docker push ${ECR_URL}/${CLIENT_IMAGE_NAME}:${IMAGE_TAG}
                    docker push ${ECR_URL}/${CLIENT_IMAGE_NAME}:latest
                    docker push ${ECR_URL}/${SERVER_IMAGE_NAME}:${IMAGE_TAG}
                    docker push ${ECR_URL}/${SERVER_IMAGE_NAME}:latest
                """
            }
        }

        stage('Deploy to Kubernetes') {
            steps {
                echo 'Deploying application to Kubernetes...'

                sh '''
                    set -e

                    export CLIENT_IMAGE="${ECR_URL}/${CLIENT_IMAGE_NAME}:${IMAGE_TAG}"
                    export SERVER_IMAGE="${ECR_URL}/${SERVER_IMAGE_NAME}:${IMAGE_TAG}"

                    echo "Deploying client image: ${CLIENT_IMAGE}"
                    echo "Deploying server image: ${SERVER_IMAGE}"

                    kubectl apply -f k8s/00-namespace.yaml

                    kubectl apply -f k8s/01-configmap.yaml
                    kubectl apply -f k8s/02-secret.yaml

                    envsubst < k8s/03-server-deployment.yaml \
                      | kubectl apply -f -

                    kubectl apply -f k8s/04-server-service.yaml

                    envsubst < k8s/05-client-deployment.yaml \
                      | kubectl apply -f -

                    kubectl apply -f k8s/06-client-service.yaml
                    kubectl apply -f k8s/07-ingress.yaml

                    echo "Kubernetes manifests applied successfully."
                '''
            }
        }

        stage('Cleanup') {
            steps {
                echo 'Cleaning local Docker images...'

                sh """
                    docker rmi ${ECR_URL}/${CLIENT_IMAGE_NAME}:${IMAGE_TAG} || true

                    docker rmi ${ECR_URL}/${CLIENT_IMAGE_NAME}:latest || true

                    docker rmi ${ECR_URL}/${SERVER_IMAGE_NAME}:${IMAGE_TAG} || true

                    docker rmi ${ECR_URL}/${SERVER_IMAGE_NAME}:latest || true

                    docker rmi ${CLIENT_IMAGE_NAME}:${IMAGE_TAG} || true

                    docker rmi ${SERVER_IMAGE_NAME}:${IMAGE_TAG} || true
                """
            }
        }
    }
}